# Copy to .env and fill in your keys.

SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# CV password — protects the whole site (CV, transcript, jobs). Set your password below.
ENABLE_CV_PASSWORD=true
CV_ACCESS_PASSWORD=your-password-here

# Saved de/no HTML in cvapp/data/document_i18n/ (fast page loads). Regenerate after English edits:
#   python manage.py translate_documents --doc transcript --force
DOCUMENT_I18N_ALLOW_LIVE=false
MISTRAL_API_KEY=

# --- Job matching (free sources work without anything below) ---
JOB_DEFAULT_MIN_SCORE=50
JOB_DEFAULT_MAX_JOBS=250
# broad = mass opportunities list; strict = only high must-have match
JOB_MATCH_MODE=broad
JOB_BROAD_SCORE_MIN=50
JOB_DISPLAY_MIN_SCORE=50
JOB_PREFILTER_MODE=wide
ARBEITSAGENTUR_MAX_SEARCHES=72
EURES_MAX_KEYWORDS=18
EURES_MAX_PAGES=3
# More jobs on strict apply list (lower = more matches):
JOB_APPLY_SCORE_MIN=50
JOB_APPLY_RATIO_MIN=0.38

# FREE job sources (merged automatically on every Refresh):
#   Arbeitsagentur (official DE), Arbeitnow, StepStone/Indeed/Adzuna RSS, optional Jooble
# Verify Apify: python jobsearch/scripts/verify_apify_dataset.py
# Daily run: run_daily_jobs.bat

# Optional: Jooble aggregates Indeed/StepStone-style listings (free key at jooble.org)
# JOOBLE_API_KEY=

# Optional paid Apify (LinkedIn/Indeed) — NOT required
# APIFY_TOKEN=
# APIFY_AUTO_RUN=true
# APIFY_DATASET_IDS=indeed:datasetId
